# Minimal configuration for local Flask development (HTML/CSS testing)
# Copy this to .env.dev or use as is

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-secret-key-change-in-production

# Database (SQLite for local development - lightweight)
SQLALCHEMY_DATABASE_URI=sqlite:///data/smartlib.db

# Redis (optional - can skip for HTML/CSS testing)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Vector Store Mode
VECTOR_STORE_PROVIDER=CHROMA
VECTOR_STORE_MODE=user

# Data paths
DATA_VOLUME_PATH=./data
UPLOAD_FOLDER=./data/uploads
CHROMA_PERSIST_DIR=./data/chromadb

# App Edition
APP_EDITION=BASIC

# OCR Settings (can disable for testing)
IS_ENABLED_OCR=0
IS_AUTO_OCR=0

# Azure OpenAI (optional for HTML/CSS testing - just use dummy values)
AZURE_OPENAI_ENDPOINT=https://dummy.openai.azure.com/
AZURE_OPENAI_API_KEY=dummy-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Disable embedding warmup for faster startup
EMBEDDING_WARMUP_ENABLED=false

# Local mode
LOCAL_MODE=true
