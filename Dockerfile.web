# syntax=docker/dockerfile:1.5

FROM node:20-alpine AS assets
WORKDIR /app
COPY package.json ./
RUN npm install --silent
COPY vite.config.js ./
COPY static ./static
RUN npm run build

FROM node:20-alpine AS frontend
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install --silent
COPY frontend/ ./
RUN npm run build

FROM node:20-alpine AS admin_frontend
WORKDIR /app
COPY admin-frontend/package.json admin-frontend/package-lock.json* ./
RUN npm install --silent
COPY admin-frontend/ ./
RUN npm run build

FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=on \
    PYTHONPATH=/app

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    libffi-dev \
    libpq-dev \
    libjpeg-dev \
    zlib1g-dev \
    libpng-dev \
    libfreetype6-dev \
    liblcms2-dev \
    libtiff-dev \
    libwebp-dev \
    libxml2-dev \
    libxslt1-dev \
    libssl-dev \
    pkg-config \
    openssh-server \
    && rm -rf /var/lib/apt/lists/*

# Configure SSH for Azure App Service access
ARG SSH_USERNAME=appuser
ENV SSH_USERNAME=${SSH_USERNAME}
RUN useradd -m -s /bin/bash ${SSH_USERNAME} \
    && mkdir -p /var/run/sshd \
    && sed -i 's/^#\?Port .*/Port 2222/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?PasswordAuthentication .*/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?PermitRootLogin .*/PermitRootLogin no/' /etc/ssh/sshd_config \
    && echo "AllowUsers ${SSH_USERNAME}" >> /etc/ssh/sshd_config \
    && echo "ClientAliveInterval 180" >> /etc/ssh/sshd_config \
    && echo "ClientAliveCountMax 3" >> /etc/ssh/sshd_config \
    && echo "UseDNS no" >> /etc/ssh/sshd_config

ARG INSTALL_WEB_EXTRAS=false

COPY requirements-web.txt /tmp/requirements.txt
COPY requirements-web-extras.txt /tmp/requirements-extras.txt

# Use BuildKit cache mount for pip to speed up rebuilds
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip \
    && pip install -r /tmp/requirements.txt \
    && if [ "$INSTALL_WEB_EXTRAS" = "true" ]; then \
    pip install --extra-index-url https://download.pytorch.org/whl/cpu -r /tmp/requirements-extras.txt; \
    fi

COPY . /app
COPY --from=assets /app/static/dist /app/static/dist
COPY --from=frontend /app/dist /app/frontend/dist
COPY --from=admin_frontend /app/dist /app/admin-frontend/dist

RUN chmod +x docker-entrypoint.sh

EXPOSE 8000 2222

ENTRYPOINT ["./docker-entrypoint.sh"]
CMD ["web"]
