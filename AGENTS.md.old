2. Create pyproject.toml for modern Python packaging
   ```bash
   cat > /home/mlk/smartlib/pyproject.toml << 'EOF'
   [build-system]
   requires = ["setuptools>=61.0"]
   build-backend = "setuptools.build_meta"

   [project]
   name = "smartlib"
   version = "0.1.0"
   authors = [
       {name = "SmartLib Team", email = "example@example.com"},
   ]
   description = "Intelligent Document RAG System"
   readme = "README.md"
   requires-python = ">=3.10"
   classifiers = [
       "Programming Language :: Python :: 3",
       "License :: OSI Approved :: MIT License",
       "Operating System :: OS Independent",
   ]
   
   [project.urls]
   "Homepage" = "https://github.com/yourusername/smartlib"
   "Bug Tracker" = "https://github.com/yourusername/smartlib/issues"
   
   [tool.black]
   line-length = 88
   
   [tool.isort]
   profile = "black"
   
   [tool.pytest.ini_options]
   testpaths = ["tests"]
   python_files = "test_*.py"
   EOF
   ```

### Phase 4: Environment and Configuration Files

1. Create environment file template
   ```bash
   cat > /home/mlk/smartlib/.env.example << 'EOF'
   # SmartLib Environment Configuration
   
   # Application Settings
   DEBUG=False
   SECRET_KEY=your-secret-key
   SQLALCHEMY_TRACK_MODIFICATIONS=False
   
   # Database Settings
   # SQLite (Basic)
   SQLALCHEMY_DATABASE_URI=sqlite:///data/app.db
   
   # PostgreSQL (Enterprise)
   # SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost/dbname
   
   # Azure Settings
   AZURE_OPENAI_API_TYPE=azure
   AZURE_OPENAI_API_KEY=your-azure-openai-key
   AZURE_OPENAI_API_BASE=https://your-instance.openai.azure.com
   AZURE_OPENAI_API_VERSION=2023-07-01-preview
   
   # Azure Document Intelligence
   AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-instance.cognitiveservices.azure.com/
   AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key
   
   # Vector Store Settings
   VECTOR_STORE_PROVIDER=chromadb
   VECTOR_STORE_PATH=./data/vectorstore
   DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2
   
   # Celery Settings
   CELERY_BROKER_URL=redis://redis:6379/0
   CELERY_RESULT_BACKEND=redis://redis:6379/0
   
   # Authentication Settings
   LOCAL_MODE=true
   # AZURE_TENANT_ID=your-azure-tenant-id
