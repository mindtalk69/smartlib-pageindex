   venv/
   .venv/
   ENV/
   
   # Flask
   instance/
   .webassets-cache
   
   # Database
   *.db
   *.sqlite
   *.sqlite3
   
   # Docker
   .dockerignore
   
   # Logs
   *.log
   
   # Environment
   .env
   .env.*
   !.env.example
   
   # IDE
   .idea/
   .vscode/
   *.swp
   *.swo
   
