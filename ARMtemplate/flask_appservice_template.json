{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "The Azure AD tenant ID (required)"
      }
    },
  "azureOpenAIKey": {
    "type": "secureString",
    "defaultValue": "[reference(resourceId('Microsoft.KeyVault/vaults/secrets', 'myKeyVaultName', 'AZURE_OPENAI_API_KEY')).value]"
  },
  "azureOpenAIEndpoint": {
    "type": "string",
    "defaultValue": "",
    "metadata": {
      "description": "Fill with: [reference(resourceId('Microsoft.KeyVault/vaults/secrets', 'myKeyVaultName', 'AZURE_OPENAI_ENDPOINT')).value]"
    }
  },
  "azureOpenAIDeployment": {
    "type": "string",
    "defaultValue": "",
    "metadata": {
      "description": "Fill with: [reference(resourceId('Microsoft.KeyVault/vaults/secrets', 'myKeyVaultName', 'AZURE_OPENAI_DEPLOYMENT')).value]"
    }
  },
  "azureOpenAIAPIVersion": {
    "type": "string",
    "defaultValue": "2024-10-21",
    "metadata": {
      "description": "Fill with: [reference(resourceId('Microsoft.KeyVault/vaults/secrets', 'myKeyVaultName', 'AZURE_OPENAI_API_VERSION')).value]"
    }
  },
  "docIntelligenceEndpoint": {
    "type": "string",
    "defaultValue": "",
    "metadata": {
      "description": "Azure Document Intelligence endpoint URL (e.g., https://<resource>.cognitiveservices.azure.com/)"
    }
  },
  "docIntelligenceKeySecretUri": {
    "type": "string",
    "defaultValue": "",
    "metadata": {
      "description": "Key Vault secret URI containing the Azure Document Intelligence key"
    }
  },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account name that hosts the shared Azure Files share."
      }
    },
    "storageAccountKey": {
      "type": "securestring",
      "metadata": {
        "description": "Access key for the storage account used to mount shared storage."
      }
    },
    "dataShareName": {
      "type": "string",
      "metadata": {
        "description": "Azure Files share name mounted at /home/data."
      }
    },
    "azureEmbeddingDeployment": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "description": "Azure OpenAI embedding deployment name used by the web app."
      }
    },
    "openAIAzureName": {
    "type": "string",
    "metadata": {
      "description": "Name of the existing Azure OpenAI resource that must exist prior to deployment."
    }
  },
    "webAppName": {
      "type": "string",
      "defaultValue": "flaskrag3-app",
      "metadata": {
        "description": "Name of the Web App"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "indonesiacentral",
      "allowedValues": [
        "indonesiacentral",
        "southeastasia",
        "eastasia"
      ],
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "acrLoginServer": {
      "type": "string",
      "defaultValue": "atgmpnregistry.azurecr.io",
      "metadata": {
        "description": "Full login server name of your existing Azure Container Registry (e.g., myregistry.azurecr.io)"
      }
    },
    "acrUsername": {
      "type": "string",
      "defaultValue": "atgmpnregistry",
      "metadata": {
        "description": "Username for the Azure Container Registry"
      }
    },
    "acrPassword": {
      "type": "securestring",
      "defaultValue": "YKcqIqD4SROyXx366E4VyicHuq+qtRN+LaB6mnjCgb+ACRB4aJoJ",
      "metadata": {
        "description": "Password for the Azure Container Registry"
      }
    },
    "webDockerImageName": {
      "type": "string",
      "defaultValue": "smartlib-web:latest",
      "metadata": {
        "description": "Docker image name for the web app (e.g., smartlib-web:latest)"
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "[concat('kv', uniqueString(concat(parameters('webAppName'), utcNow())))]",
      "metadata": {
        "description": "Optional. Name of the Key Vault. If not specified, a unique name will be generated. Must be globally unique, 3-24 characters, alphanumeric, and no hyphens at start/end."
      }
    },    
    "APP_CLIENT_ID": {
      "type": "string",
      "metadata": {
        "description": "Application Client ID"
      }
    },
    "APP_CLIENT_SECRET": {
      "type": "securestring",
      "metadata": {
        "description": "Application Client Secret"
      }
    },
    "appAdminUsername": {
      "type": "string",
      "defaultValue": "admin",
      "metadata": {
        "description": "Admin username for the application"
      }
    },
    "appAdminPassword": {
      "type": "securestring",
      "defaultValue": "admin",
      "metadata": {
        "description": "Admin password for the application"
      }
    },
    "appAdminPasswordSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin password (overrides appAdminPassword when provided)"
      }
    },
    "appAdminEmail": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Admin email for the application"
      }
    },
    "appAdminEmailSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin email (overrides appAdminEmail when provided)"
      }
    },    
    "autoPromoteAdmin": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Bootstrap the admin account on startup (set to false to disable)"
      }
    },
    "runDefaultModels": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Set to true to run create_default_models.py during startup"
      }
    },
    "defaultEmbeddingModel": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "description": "Default embedding model to load on startup"
      }
    },
    "appServicePlanSkuName": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",        
        "S1",
        "P1v2"
      ],
      "metadata": {
        "description": "The SKU for the App Service Plan. Determines the pricing tier and capacity. B1=Basic, S1=Standard, P1v2=PremiumV2."
      }
    }
  },
  "variables": {
    "appServicePlanName": "[concat(parameters('webAppName'), '-plan')]",
    "redisCacheName": "[concat(parameters('webAppName'), '-redis')]",
    "skuMap": {
      "B1": {
        "name": "B1",
        "tier": "Basic"
      },
      "S1": {
        "name": "S1",
        "tier": "Standard"
      },
      "P1v2": {
        "name": "P1v2",
        "tier": "PremiumV2"
      }
    },
    "selectedSku": "[variables('skuMap')[parameters('appServicePlanSkuName')]]"
  },
  "resources": [
    {
      "type": "Microsoft.Cache/Redis",
      "apiVersion": "2023-08-01",
      "name": "[variables('redisCacheName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "Basic",
          "family": "C",
          "capacity": 0
        },
        "enableNonSslPort": false,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-03-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": "[variables('selectedSku')]",
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
        "[resourceId('Microsoft.Cache/Redis', variables('redisCacheName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "siteConfig": {
  "appSettings": [
    {
      "name": "CELERY_BROKER_URL",
      "value": "[concat('rediss://:', listKeys(resourceId('Microsoft.Cache/Redis', variables('redisCacheName')), '2023-08-01').primaryKey, '@', reference(resourceId('Microsoft.Cache/Redis', variables('redisCacheName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
    },
    {
      "name": "CELERY_RESULT_BACKEND",
      "value": "[concat('rediss://:', listKeys(resourceId('Microsoft.Cache/Redis', variables('redisCacheName')), '2023-08-01').primaryKey, '@', reference(resourceId('Microsoft.Cache/Redis', variables('redisCacheName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
    },
    {
      "name": "AZURE_OPENAI_API_KEY",
      "value": "[parameters('azureOpenAIKey')]"
    },
    {
      "name": "AZURE_OPENAI_ENDPOINT",
      "value": "[parameters('azureOpenAIEndpoint')]"
    },
    {
      "name": "AZURE_OPENAI_DEPLOYMENT",
      "value": "[parameters('azureOpenAIDeployment')]"
    },
    {
      "name": "AZURE_OPENAI_API_VERSION",
      "value": "[parameters('azureOpenAIAPIVersion')]"
    },
    {
      "name": "DOC_INTELLIGENCE_ENDPOINT",
      "value": "[parameters('docIntelligenceEndpoint')]"
    },
    {
      "name": "DOC_INTELLIGENCE_KEY",
      "value": "[if(equals(parameters('docIntelligenceKeySecretUri'), ''), '', concat('@Microsoft.KeyVault(SecretUri=', parameters('docIntelligenceKeySecretUri'), ')'))]"
    },
    {
      "name": "WEBSITES_PORT",
      "value": "8000"
    },
    {
      "name": "DOCKER_REGISTRY_SERVER_URL",
      "value": "[concat('https://', parameters('acrLoginServer'))]"
    },
    {
      "name": "DOCKER_REGISTRY_SERVER_USERNAME",
      "value": "[parameters('acrUsername')]"
    },
    {
      "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
      "value": "[parameters('acrPassword')]"
    },
    {
      "name": "KEY_VAULT_NAME",
      "value": "[parameters('keyVaultName')]"
    },
    {
      "name": "WEB_APP_NAME",
      "value": "[parameters('webAppName')]"
    },
    {
      "name": "APP_CLIENT_ID",
      "value": "[parameters('APP_CLIENT_ID')]"
    },
    {
      "name": "APP_CLIENT_SECRET",
      "value": "[parameters('APP_CLIENT_SECRET')]"
    },    
    {
      "name": "APP_ADMIN_USERNAME",
      "value": "[parameters('appAdminUsername')]"
    },
    {
      "name": "APP_ADMIN_PASSWORD",
      "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
    },
    {
      "name": "APP_ADMIN_EMAIL",
      "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
    },
    {
      "name": "AUTO_PROMOTE_ADMIN",
      "value": "[if(parameters('autoPromoteAdmin'), 'true', 'false')]"
    },
    {
      "name": "ADMIN_USERNAME",
      "value": "[parameters('appAdminUsername')]"
    },
    {
      "name": "ADMIN_PASSWORD",
      "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
    },
    {
      "name": "ADMIN_EMAIL",
      "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
    },
            {
               "name": "DEFAULT_EMBEDDING_MODEL",
               "value": "[parameters('azureEmbeddingDeployment')]"
             },
             {
               "name": "AZURE_EMBEDDING_DEPLOYMENT",
               "value": "[parameters('azureEmbeddingDeployment')]"
             },

    {
      "name": "DATA_VOLUME_PATH",
      "value": "/home/data"
    },
    {
      "name": "UPLOAD_TEMP_DIR",
      "value": "/home/data/tmp_uploads"
    },
    {
      "name": "MAP_PUBLIC_DIR",
      "value": "/home/data/maps"
    },
    {
      "name": "VECTOR_STORE_BASE_PATH",
      "value": "/home/data/chroma"
    },
    {
      "name": "SQLALCHEMY_DATABASE_URI",
      "value": "sqlite:////home/data/app.db"
    },

    {
      "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
      "value": "true"
    },
    {
      "name": "DOCKER_ENABLE_CI",
      "value": "true"
    },
    {
      "name": "RUN_DEFAULT_MODELS",
      "value": "[if(parameters('runDefaultModels'), 'true', 'false')]"
    }
  ],
  "linuxFxVersion": "[concat('DOCKER|', parameters('acrLoginServer'), '/', parameters('webDockerImageName'))]",
  "appCommandLine": "./docker-entrypoint.sh web",
  "alwaysOn": true,
  "azureStorageAccounts": {
    "data": {
      "type": "AzureFiles",
      "accountName": "[parameters('storageAccountName')]",
      "shareName": "[parameters('dataShareName')]",
      "accessKey": "[parameters('storageAccountKey')]",
      "mountPath": "/home/data"
    }
  }
}
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[concat(parameters('webAppName'), '-ai')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-02-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[parameters('tenantId')]",
        "enableRbacAuthorization": true,
        "enabledForDeployment": true,
        "enabledForDiskEncryption": true,
        "enabledForTemplateDeployment": true
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Web/sites', parameters('webAppName')), resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ],
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "properties": {
                "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', 'b86a8fe4-44ce-4948-aee5-eccb2c155cd7')]",         "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2022-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('webAppName'), '.azurewebsites.net')]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[parameters('acrLoginServer')]"
    },
    "keyVaultName": {
    "type": "string",
    "value": "[parameters('keyVaultName')]"
  }
  }
}
