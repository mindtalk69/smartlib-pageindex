{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "The Azure AD tenant ID (required)"
      }
    },
    "existingRedisName": {
      "type": "string",
      "metadata": {
        "description": "The name of the existing Azure Cache for Redis instance."
      }
    },
    "existingRedisResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "The resource group of the existing Azure Cache for Redis instance. Defaults to the current resource group."
      }
    },
    "existingKeyVaultName": {
      "type": "string",
      "metadata": {
        "description": "The name of the existing Azure Key Vault instance."
      }
    },
    "existingKeyVaultResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "The resource group of the existing Azure Key Vault instance. Defaults to the current resource group."
      }
    },
    "createRoleAssignment": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "If true, a role assignment will be created to grant the web app access to the Key Vault. Set to false on subsequent deployments to avoid errors."
      }
    },
  "azureOpenAIKey": {
    "type": "secureString",
    "defaultValue": "[reference(resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults/secrets', parameters('existingKeyVaultName'), 'AZURE_OPENAI_API_KEY')).value]"
  },
  "azureOpenAIEndpoint": {
    "type": "string",
    "defaultValue": "",
    "metadata": {
      "description": "Fill with: [reference(resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults/secrets', parameters('existingKeyVaultName'), 'AZURE_OPENAI_ENDPOINT')).value]"
    }
  },
  "azureOpenAIDeployment": {
    "type": "string",
    "defaultValue": "",
    "metadata": {
      "description": "Fill with: [reference(resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults/secrets', parameters('existingKeyVaultName'), 'AZURE_OPENAI_DEPLOYMENT')).value]"
    }
  },
  "azureOpenAIAPIVersion": {
    "type": "string",
    "defaultValue": "2024-10-21",
    "metadata": {
      "description": "Fill with: [reference(resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults/secrets', parameters('existingKeyVaultName'), 'AZURE_OPENAI_API_VERSION')).value]"
    }
  },
    "openAIAzureName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing Azure OpenAI resource that must exist prior to deployment."
      }
    },
    "appPrefix": {
      "type": "string",
      "defaultValue": "smartlib-basic",
      "metadata": {
        "description": "Prefix for resource naming (smartlib-basic for marketplace)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "indonesiacentral",
      "allowedValues": [
        "indonesiacentral",
        "southeastasia",
        "eastasia"
      ],
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "acrLoginServer": {
      "type": "string",
      "defaultValue": "atgmpnregistry.azurecr.io",
      "metadata": {
        "description": "Full login server name of your existing Azure Container Registry (e.g., myregistry.azurecr.io)"
      }
    },
    "acrUsername": {
      "type": "string",
      "defaultValue": "atgmpnregistry",
      "metadata": {
        "description": "Username for the Azure Container Registry"
      }
    },
    "acrPassword": {
      "type": "secureString",
      "defaultValue": "YKcqIqD4SROyXx366E4VyicHuq+qtRN+LaB6mnjCgb+ACRB4aJoJ",
      "metadata": {
        "description": "Password for the Azure Container Registry"
      }
    },
    "webDockerImageName": {
      "type": "string",
      "defaultValue": "smartlib-web:latest",
      "metadata": {
        "description": "Docker image name for the web app (e.g., smartlib-web:latest)"
      }
    },
    "workerDockerImageName": {
      "type": "string",
      "defaultValue": "smartlib-worker:latest",
      "metadata": {
        "description": "Docker image name for the worker app (e.g., smartlib-worker:latest)"
      }
    },
    "APP_CLIENT_ID": {
      "type": "string",
      "metadata": {
        "description": "Application Client ID"
      }
    },
    "APP_CLIENT_SECRET": {
      "type": "secureString",
      "metadata": {
        "description": "Application Client Secret"
      }
    },
    "appAdminUsername": {
      "type": "string",
      "defaultValue": "admin",
      "metadata": {
        "description": "Admin username for the application"
      }
    },
    "appAdminPassword": {
      "type": "secureString",
      "defaultValue": "admin",
      "metadata": {
        "description": "Admin password for the application"
      }
    },
    "appAdminPasswordSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin password (overrides appAdminPassword when provided)"
      }
    },
    "appAdminEmail": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Admin email for the application"
      }
    },
    "appAdminEmailSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin email (overrides appAdminEmail when provided)"
      }
    },    
    "autoPromoteAdmin": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Bootstrap the admin account on startup (set to false to disable)"
      }
    },
    "runDefaultModels": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Set to true to run create_default_models.py during startup"
      }
    },
    "defaultEmbeddingModel": {
      "type": "string",
      "defaultValue": "all-MiniLM-L6-v2",
      "metadata": {
        "description": "Default embedding model to load on startup"
      }
    },
    "appServicePlanSkuName": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",        
        "S1",
        "P1v2"
      ],
      "metadata": {
        "description": "The SKU for the shared App Service Plan. Determines the pricing tier and capacity. B1=Basic, S1=Standard, P1v2=PremiumV2."
      }
    }
  },
  "variables": {
    "sharedAppServicePlanName": "[concat(parameters('appPrefix'), '-plan')]",
    "webAppName": "[concat(parameters('appPrefix'), '-web')]",
    "workerAppName": "[concat(parameters('appPrefix'), '-worker')]",
    "skuMap": {
      "B1": {
        "name": "B1",
        "tier": "Basic"
      },
      "S1": {
        "name": "S1",
        "tier": "Standard"
      },
      "P1v2": {
        "name": "P1v2",
        "tier": "PremiumV2"
      }
    },
    "selectedSku": "[variables('skuMap')[parameters('appServicePlanSkuName')]]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-03-01",
      "name": "[variables('sharedAppServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": "[variables('selectedSku')]",
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', parameters('acrLoginServer'), '/', parameters('webDockerImageName'))]",
          "appCommandLine": "./docker-entrypoint.sh web",
          "alwaysOn": true,
          "appSettings": [
            {
              "name": "CELERY_BROKER_URL",
              "value": "[concat('rediss://:', listKeys(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').primaryKey, '@', reference(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
            },
            {
              "name": "CELERY_RESULT_BACKEND",
              "value": "[concat('rediss://:', listKeys(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').primaryKey, '@', reference(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
            },
            {
              "name": "AZURE_OPENAI_API_KEY",
              "value": "[parameters('azureOpenAIKey')]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[parameters('azureOpenAIEndpoint')]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[parameters('azureOpenAIDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_API_VERSION",
              "value": "[parameters('azureOpenAIAPIVersion')]"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8000"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "true"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[concat('https://', parameters('acrLoginServer'))]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[parameters('acrUsername')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "DOCKER_ENABLE_CI",
              "value": "true"
            },
            {
              "name": "KEY_VAULT_NAME",
              "value": "[parameters('existingKeyVaultName')]"
            },
            {
              "name": "WEB_APP_NAME",
              "value": "[variables('webAppName')]"
            },
            {
              "name": "APP_CLIENT_ID",
              "value": "[parameters('APP_CLIENT_ID')]"
            },
            {
              "name": "APP_CLIENT_SECRET",
              "value": "[parameters('APP_CLIENT_SECRET')]"
            },
            {
              "name": "APP_ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "APP_ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "APP_ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "AUTO_PROMOTE_ADMIN",
              "value": "[if(parameters('autoPromoteAdmin'), 'true', 'false')]"
            },
            {
              "name": "ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "DEFAULT_EMBEDDING_MODEL",
              "value": "[parameters('defaultEmbeddingModel')]"
            },
            {
              "name": "DATA_VOLUME_PATH",
              "value": "/home/data"
            },
            {
              "name": "UPLOAD_TEMP_DIR",
              "value": "/home/data/tmp_uploads"
            },
            {
              "name": "MAP_PUBLIC_DIR",
              "value": "/home/data/maps"
            },
            {
              "name": "VECTOR_STORE_BASE_PATH",
              "value": "/home/data/chroma"
            },
            {
              "name": "SQLALCHEMY_DATABASE_URI",
              "value": "sqlite:////home/data/app.db"
            },
            {
              "name": "RUN_DEFAULT_MODELS",
              "value": "[if(parameters('runDefaultModels'), 'true', 'false')]"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[variables('workerAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', parameters('acrLoginServer'), '/', parameters('workerDockerImageName'))]",
          "appCommandLine": "./docker-entrypoint.sh worker",
          "alwaysOn": true,
          "appSettings": [
            {
              "name": "CELERY_BROKER_URL",
              "value": "[concat('rediss://:', listKeys(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').primaryKey, '@', reference(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
            },
            {
              "name": "CELERY_RESULT_BACKEND",
              "value": "[concat('rediss://:', listKeys(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').primaryKey, '@', reference(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
            },
            {
              "name": "AZURE_OPENAI_API_KEY",
              "value": "[parameters('azureOpenAIKey')]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[parameters('azureOpenAIEndpoint')]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[parameters('azureOpenAIDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_API_VERSION",
              "value": "[parameters('azureOpenAIAPIVersion')]"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "true"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[concat('https://', parameters('acrLoginServer'))]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[parameters('acrUsername')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "DOCKER_ENABLE_CI",
              "value": "true"
            },
            {
              "name": "KEY_VAULT_NAME",
              "value": "[parameters('existingKeyVaultName')]"
            },
            {
              "name": "APP_CLIENT_ID",
              "value": "[parameters('APP_CLIENT_ID')]"
            },
            {
              "name": "APP_CLIENT_SECRET",
              "value": "[parameters('APP_CLIENT_SECRET')]"
            },
            {
              "name": "APP_ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "APP_ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "APP_ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "AUTO_PROMOTE_ADMIN",
              "value": "[if(parameters('autoPromoteAdmin'), 'true', 'false')]"
            },
            {
              "name": "ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "DEFAULT_EMBEDDING_MODEL",
              "value": "[parameters('defaultEmbeddingModel')]"
            },
            {
              "name": "DATA_VOLUME_PATH",
              "value": "/home/data"
            },
            {
              "name": "UPLOAD_TEMP_DIR",
              "value": "/home/data/tmp_uploads"
            },
            {
              "name": "MAP_PUBLIC_DIR",
              "value": "/home/data/maps"
            },
            {
              "name": "VECTOR_STORE_BASE_PATH",
              "value": "/home/data/chroma"
            },
            {
              "name": "SQLALCHEMY_DATABASE_URI",
              "value": "sqlite:////home/data/app.db"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8080"
            },
            {
              "name": "WORKER_HEALTH_PORT",
              "value": "8080"
            },
            {
              "name": "ENABLE_WORKER_HEALTH_SERVER",
              "value": "true"
            },
            {
              "name": "WEBSITES_CONTAINER_START_TIME_LIMIT",
              "value": "400"
            },
            {
              "name": "RUN_DEFAULT_MODELS",
              "value": "[if(parameters('runDefaultModels'), 'true', 'false')]"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[concat(variables('webAppName'), '-ai')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web"
      }
    },
    {
      "condition": "[parameters('createRoleAssignment')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Web/sites', variables('webAppName')), resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults', parameters('existingKeyVaultName')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]"
      ],
      "scope": "[resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults', parameters('existingKeyVaultName'))]",
      "properties": {
                "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', 'b86a8fe4-44ce-4948-aee5-eccb2c155cd7')]",         "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2022-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "condition": "[parameters('createRoleAssignment')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Web/sites', variables('workerAppName')), resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults', parameters('existingKeyVaultName')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('workerAppName'))]"
      ],
      "scope": "[resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults', parameters('existingKeyVaultName'))]",
      "properties": {
                "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', 'b86a8fe4-44ce-4948-aee5-eccb2c155cd7')]",         "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('workerAppName')), '2022-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[concat('https://', variables('webAppName'), '.azurewebsites.net')]"
    },
    "workerAppName": {
      "type": "string",
      "value": "[variables('workerAppName')]"
    },
    "sharedAppServicePlan": {
      "type": "string",
      "value": "[variables('sharedAppServicePlanName')]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[parameters('acrLoginServer')]"
    },
    "keyVaultName": {
    "type": "string",
    "value": "[parameters('existingKeyVaultName')]"
  },
  "costSavings": {
    "type": "object",
    "value": {
      "monthlyCost": "~$30",
      "savings": "~$13 (30%)",
      "description": "Shared App Service Plan reduces costs compared to separate plans"
    }
  }
  }
}
