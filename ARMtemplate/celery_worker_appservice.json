{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "existingRedisName": {
      "type": "string",
      "metadata": {
        "description": "The name of the existing Azure Cache for Redis instance."
      }
    },
    "existingRedisResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "The resource group of the existing Azure Cache for Redis instance."
      }
    },
    "existingKeyVaultName": {
      "type": "string",
      "metadata": {
        "description": "The name of the existing Azure Key Vault instance."
      }
    },
    "existingKeyVaultResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "The resource group of the existing Azure Key Vault instance."
      }
    },
    "azureOpenAIKey": {
      "type": "secureString",
      "metadata": {
        "displayName": "Azure Open AI Key",
        "description": "Azure OpenAI API Key"
      }
    },
    "azureOpenAIKeySecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "displayName": "Azure Open AI Key Secret URI",
        "description": "Optional Key Vault secret URI containing the Azure OpenAI API key."
      }
    },
    "openAIAzureName": {
      "type": "string",
      "metadata": {
        "displayName": "Azure Open AI Name",
        "description": "Name of the existing Azure OpenAI resource that must exist prior to deployment."
      }
    },
    "azureOpenAIEndpoint": {
      "type": "string",
      "metadata": {
        "displayName": "Azure Open AI Endpoint",
        "description": "Azure OpenAI Endpoint"
      }
    },
    "azureOpenAIDeployment": {
      "type": "string",
      "metadata": {
        "displayName": "Azure Open AI Deployment Model",
        "description": "Azure OpenAI Deployment Name"
      }
    },
    "azureOpenAIAPIVersion": {
      "type": "string",
      "defaultValue": "2024-10-21",
      "metadata": {
        "displayName": "Azure Open AI API Version",
        "description": "Azure OpenAI API Version"
      }
    },
    "docIntelligenceEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure Document Intelligence endpoint URL (e.g., https://<resource>.cognitiveservices.azure.com/)"
      }
    },
    "docIntelligenceKeySecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Key Vault secret URI containing the Azure Document Intelligence key"
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account name that hosts the shared Azure Files share."
      }
    },
    "storageAccountKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Access key for the storage account used to mount shared storage (used when no Key Vault secret URI provided)."
      }
    },
    "storageAccountKeySecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Key Vault secret URI containing the storage account key."
      }
    },
    "dataShareName": {
      "type": "string",
      "metadata": {
        "description": "Azure Files share name mounted at /home/data."
      }
    },
    "azureEmbeddingDeployment": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "displayName": "Azure Embedding Deployment",
        "description": "Azure OpenAI embedding deployment name used by the worker."
      }
    },
    "defaultEmbeddingModel": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "displayName": "Default Embedding Model",
        "description": "Default embedding model to load on startup"
      }
    },
    "workerAppName": {
      "type": "string",
      "defaultValue": "flaskrag3-worker",
      "metadata": {
        "description": "Name of the Celery Worker App Service"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "indonesiacentral",
      "allowedValues": [
        "indonesiacentral",
        "southeastasia",
        "eastasia"
      ],
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "acrLoginServer": {
      "type": "string",
      "defaultValue": "atgmpnregistry.azurecr.io",
      "metadata": {
        "description": "Full login server name of your Azure Container Registry"
      }
    },
    "acrUsername": {
      "type": "string",
      "defaultValue": "atgmpnregistry",
      "metadata": {
        "description": "Username for the Azure Container Registry"
      }
    },
    "acrPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Password for the Azure Container Registry"
      }
    },
    "workerDockerImageName": {
      "type": "string",
      "defaultValue": "smartlib-worker:latest",
      "metadata": {
        "description": "Docker image name for the worker app"
      }
    },
    "APP_CLIENT_ID": {
      "type": "string",
      "metadata": {
        "description": "Application Client ID"
      }
    },
    "APP_CLIENT_SECRET": {
      "type": "securestring",
      "metadata": {
        "description": "Application Client Secret"
      }
    },
    "appAdminUsername": {
      "type": "string",
      "defaultValue": "admin",
      "metadata": {
        "description": "Admin username"
      }
    },
    "appAdminPassword": {
      "type": "securestring",
      "defaultValue": "admin",
      "metadata": {
        "description": "Admin password"
      }
    },
    "appAdminPasswordSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin password (overrides appAdminPassword when provided)"
      }
    },
    "appAdminEmail": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Admin email"
      }
    },
    "appAdminEmailSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin email (overrides appAdminEmail when provided)"
      }
    },
    "appServicePlanSkuName": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "S1",
        "P1v2"
      ],
      "metadata": {
        "description": "SKU for the Worker App Service Plan. B1 is sufficient for background workers."
      }
    }
  },
  "variables": {
    "appServicePlanName": "[concat(parameters('workerAppName'), '-plan')]",
    "skuMap": {
      "B1": {
        "name": "B1",
        "tier": "Basic"
      },
      "S1": {
        "name": "S1",
        "tier": "Standard"
      },
      "P1v2": {
        "name": "P1v2",
        "tier": "PremiumV2"
      }
    },
    "selectedSku": "[variables('skuMap')[parameters('appServicePlanSkuName')]]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-03-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": "[variables('selectedSku')]",
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[parameters('workerAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', parameters('acrLoginServer'), '/', parameters('workerDockerImageName'))]",
          "appCommandLine": "./docker-entrypoint.sh worker",
          "alwaysOn": true,
          "azureStorageAccounts": {
            "data": {
              "type": "AzureFiles",
              "accountName": "[parameters('storageAccountName')]",
              "shareName": "[parameters('dataShareName')]",
              "accessKey": "[if(equals(parameters('storageAccountKeySecretUri'), ''), parameters('storageAccountKey'), concat('@Microsoft.KeyVault(SecretUri=', parameters('storageAccountKeySecretUri'), ')'))]",
              "mountPath": "/home/data"
            }
          },
          "appSettings": [
            {
              "name": "CELERY_BROKER_URL",
              "value": "[concat('rediss://:', listKeys(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').primaryKey, '@', reference(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
            },
            {
              "name": "CELERY_RESULT_BACKEND",
              "value": "[concat('rediss://:', listKeys(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').primaryKey, '@', reference(resourceId(parameters('existingRedisResourceGroup'), 'Microsoft.Cache/Redis', parameters('existingRedisName')), '2023-08-01').hostName, ':', 6380, '?ssl_cert_reqs=none')]"
            },
            {
              "name": "AZURE_OPENAI_API_KEY",
              "value": "[if(equals(parameters('azureOpenAIKeySecretUri'), ''), parameters('azureOpenAIKey'), concat('@Microsoft.KeyVault(SecretUri=', parameters('azureOpenAIKeySecretUri'), ')'))]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[parameters('azureOpenAIEndpoint')]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[parameters('azureOpenAIDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_API_VERSION",
              "value": "[parameters('azureOpenAIAPIVersion')]"
            },
            {
              "name": "DOC_INTELLIGENCE_ENDPOINT",
              "value": "[parameters('docIntelligenceEndpoint')]"
            },
            {
              "name": "DOC_INTELLIGENCE_KEY",
              "value": "[if(equals(parameters('docIntelligenceKeySecretUri'), ''), '', concat('@Microsoft.KeyVault(SecretUri=', parameters('docIntelligenceKeySecretUri'), ')'))]"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "true"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[concat('https://', parameters('acrLoginServer'))]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[parameters('acrUsername')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "DOCKER_ENABLE_CI",
              "value": "true"
            },
            {
              "name": "KEY_VAULT_NAME",
              "value": "[parameters('existingKeyVaultName')]"
            },
            {
              "name": "APP_CLIENT_ID",
              "value": "[parameters('APP_CLIENT_ID')]"
            },
            {
              "name": "APP_CLIENT_SECRET",
              "value": "[parameters('APP_CLIENT_SECRET')]"
            },
            {
              "name": "APP_ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "APP_ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "APP_ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "DEFAULT_EMBEDDING_MODEL",
              "value": "[parameters('azureEmbeddingDeployment')]"
            },
            {
              "name": "AZURE_EMBEDDING_DEPLOYMENT",
              "value": "[parameters('azureEmbeddingDeployment')]"
            },

            {
              "name": "DATA_VOLUME_PATH",
              "value": "/home/data"
            },
            {
              "name": "UPLOAD_TEMP_DIR",
              "value": "/home/data/tmp_uploads"
            },
            {
              "name": "MAP_PUBLIC_DIR",
              "value": "/home/data/maps"
            },
            {
              "name": "VECTOR_STORE_BASE_PATH",
              "value": "/home/data/chroma"
            },
            {
              "name": "SQLALCHEMY_DATABASE_URI",
              "value": "sqlite:////home/data/app.db"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8080"
            },
            {
              "name": "WORKER_HEALTH_PORT",
              "value": "8080"
            },
            {
              "name": "ENABLE_WORKER_HEALTH_SERVER",
              "value": "true"
            },
            {
              "name": "WEBSITES_CONTAINER_START_TIME_LIMIT",
              "value": "400"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "workerAppName": {
      "type": "string",
      "value": "[parameters('workerAppName')]"
    },
    "workerAppServicePlan": {
      "type": "string",
      "value": "[variables('appServicePlanName')]"
    }
  }
}
