{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Name of the resource group selected during deployment."
      }
    },
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "The Azure AD tenant ID (required)"
      }
    },
    "redisConnectionString": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "description": "Redis connection string (format: rediss://:password@hostname:6380?ssl_cert_reqs=none). Required if redisConnectionStringSecretUri is not provided."
      }
    },
    "redisConnectionStringSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI containing the Redis connection string. Takes precedence over redisConnectionString parameter."
      }
    },
    "redisName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the Azure Redis Cache instance (required if configureRedisFirewall is true)."
      }
    },
    "redisResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group containing the Azure Redis Cache. Defaults to the current resource group."
      }
    },
    "configureRedisFirewall": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "If true, outputs commands to configure Redis firewall rules for App Service access. Requires redisName parameter."
      }
    },
    "existingKeyVaultName": {
      "type": "string",
      "metadata": {
        "description": "The name of the existing Azure Key Vault instance."
      }
    },
    "existingKeyVaultResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "The resource group of the existing Azure Key Vault instance. Defaults to the current resource group."
      }
    },
    "createStorageRoleAssignment": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "If true, attempts automatic Storage Account role assignment creation. Default is false due to Azure limitations with cross-resource-group deployments. Create role assignments manually after deployment for production use."
      }
    },
    "azureOpenAIKey": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "displayName": "Azure Open AI Key",
        "description": "Your Azure OpenAI API Key"
      }
    },
    "azureOpenAIKeySecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "displayName": "Azure Open AI Key Secret URI",
        "description": "Optional Key Vault secret URI containing the Azure OpenAI API key."
      }
    },
    "openAIAzureName": {
      "type": "string",
      "metadata": {
        "displayName": "Azure Open AI Name",
        "description": "Name of the existing Azure OpenAI resource that must exist prior to deployment."
      }
    },
    "azureOpenAIEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "displayName": "Azure Open AI Endpoint",
        "description": "Fill with: [reference(resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults/secrets', parameters('existingKeyVaultName'), 'AZURE_OPENAI_ENDPOINT')).value]"
      }
    },
    "azureOpenAIDeployment": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "displayName": "Azure Open AI Deployment Model",
        "description": "Fill with: [reference(resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults/secrets', parameters('existingKeyVaultName'), 'AZURE_OPENAI_DEPLOYMENT')).value]"
      }
    },
    "azureOpenAIAPIVersion": {
      "type": "string",
      "defaultValue": "2024-10-21",
      "metadata": {
        "displayName": "Azure Open AI API Version",
        "description": "Fill with: [reference(resourceId(parameters('existingKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults/secrets', parameters('existingKeyVaultName'), 'AZURE_OPENAI_API_VERSION')).value]"
      }
    },
    "docIntelligenceEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure Document Intelligence endpoint URL (e.g., https://<resource>.cognitiveservices.azure.com/)"
      }
    },
    "docIntelligenceKeySecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Key Vault secret URI containing the Azure Document Intelligence key"
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account name that hosts the shared Azure Files share."
      }
    },
    "storageAccountKey": {
      "type": "securestring",
      "metadata": {
        "description": "Storage account access key for mounting Azure Files share. Required for marketplace deployments where auto-fetch may fail due to permissions."
      }
    },
    "dataShareName": {
      "type": "string",
      "metadata": {
        "description": "Azure Files share name mounted at /home/data."
      }
    },
    "storageAccountResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group containing the storage account. Defaults to the current resource group."
      }
    },
    "azureEmbeddingDeployment": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "displayName": "Azure Embedding Deployment",
        "description": "Azure OpenAI embedding deployment name used by the web and worker apps."
      }
    },
    "defaultEmbeddingModel": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "displayName": "Default Embedding Model",
        "description": "Default embedding model to load on startup"
      }
    },
    "appPrefix": {
      "type": "string",
      "defaultValue": "smartlib-basic",
      "minLength": 3,
      "maxLength": 40,
      "metadata": {
        "description": "Unique prefix for resource naming. Must be unique within your Azure subscription. Resources will be named: {prefix}-web, {prefix}-worker, {prefix}-plan. Example: smartlib-acme"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Deployment region for all resources."
      }
    },
    "webDockerImageName": {
      "type": "string",
      "defaultValue": "smartlib-web-basic:latest",
      "metadata": {
        "description": "Docker image name for the web app - Basic edition (e.g., smartlib-web-basic:latest)"
      }
    },
    "workerDockerImageName": {
      "type": "string",
      "defaultValue": "smartlib-worker-basic:latest",
      "metadata": {
        "description": "Docker image name for the worker app - Basic edition (e.g., smartlib-worker-basic:latest)"
      }
    },
    "acrPassword": {
      "type": "secureString",
      "metadata": {
        "description": "Azure Container Registry password for smartlibdev.azurecr.io"
      }
    },
    "APP_CLIENT_ID": {
      "type": "string",
      "metadata": {
        "description": "Application Client ID"
      }
    },
    "APP_CLIENT_SECRET": {
      "type": "secureString",
      "metadata": {
        "description": "Application Client Secret"
      }
    },
    "appAdminUsername": {
      "type": "string",
      "defaultValue": "admin",
      "metadata": {
        "description": "Admin username for the application"
      }
    },
    "appAdminPassword": {
      "type": "secureString",
      "metadata": {
        "description": "Admin password for the application (minimum 8 characters)"
      }
    },
    "appAdminPasswordSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin password (overrides appAdminPassword when provided)"
      }
    },
    "appAdminEmail": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Admin email for the application"
      }
    },
    "appAdminEmailSecretUri": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Key Vault secret URI for the admin email (overrides appAdminEmail when provided)"
      }
    },
    "autoPromoteAdmin": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Bootstrap the admin account on startup (set to false to disable)"
      }
    },
    "runDefaultModels": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Set to true to run create_default_models.py during startup"
      }
    },
    "appServicePlanSkuName": {
      "type": "string",
      "defaultValue": "B2",
      "allowedValues": [
        "B1",
        "B2",
        "B3",
        "S1",
        "S2",
        "S3",
        "P1v2"
      ],
      "metadata": {
        "description": "The SKU for the shared App Service Plan. B1/B2/B3=Basic tier, S1/S2/S3=Standard tier, P1v2=PremiumV2 tier. Minimum B2 (3.5GB RAM) recommended for stable operation."
      }
    },
    "enableAutomaticUpdates": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable automatic updates from SmartLib container registry"
      }
    }
  },
  "variables": {
    "acrLoginServer": "smartlibdev.azurecr.io",
    "acrUsername": "smartlibdev",
    "baseAppName": "[parameters('appPrefix')]",
    "sharedAppServicePlanName": "[concat(variables('baseAppName'), '-plan')]",
    "webAppName": "[concat(variables('baseAppName'), '-web')]",
    "workerAppName": "[concat(variables('baseAppName'), '-worker')]",
    "skuMap": {
      "B1": {
        "name": "B1",
        "tier": "Basic"
      },
      "B2": {
        "name": "B2",
        "tier": "Basic"
      },
      "B3": {
        "name": "B3",
        "tier": "Basic"
      },
      "S1": {
        "name": "S1",
        "tier": "Standard"
      },
      "S2": {
        "name": "S2",
        "tier": "Standard"
      },
      "S3": {
        "name": "S3",
        "tier": "Standard"
      },
      "P1v2": {
        "name": "P1v2",
        "tier": "PremiumV2"
      }
    },
    "selectedSku": "[variables('skuMap')[parameters('appServicePlanSkuName')]]",
    "storageAccountKeyValue": "[if(equals(parameters('storageAccountKey'), ''), listKeys(resourceId(parameters('storageAccountResourceGroup'), 'Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-04-01').keys[0].value, parameters('storageAccountKey'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-01-01",
      "name": "[variables('sharedAppServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": "[variables('selectedSku')]",
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-01-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', variables('acrLoginServer'), '/', parameters('webDockerImageName'))]",
          "appCommandLine": "./docker-entrypoint.sh web",
          "alwaysOn": true,
          "azureStorageAccounts": {
            "data": {
              "type": "AzureFiles",
              "accountName": "[parameters('storageAccountName')]",
              "shareName": "[parameters('dataShareName')]",
              "accessKey": "[variables('storageAccountKeyValue')]",
              "mountPath": "/home/data"
            }
          },
          "appSettings": [
            {
              "name": "CELERY_BROKER_URL",
              "value": "[if(not(equals(parameters('redisConnectionStringSecretUri'), '')), concat('@Microsoft.KeyVault(SecretUri=', parameters('redisConnectionStringSecretUri'), ')'), parameters('redisConnectionString'))]"
            },
            {
              "name": "CELERY_RESULT_BACKEND",
              "value": "[if(not(equals(parameters('redisConnectionStringSecretUri'), '')), concat('@Microsoft.KeyVault(SecretUri=', parameters('redisConnectionStringSecretUri'), ')'), parameters('redisConnectionString'))]"
            },
            {
              "name": "AZURE_OPENAI_API_KEY",
              "value": "[if(equals(parameters('azureOpenAIKeySecretUri'), ''), parameters('azureOpenAIKey'), concat('@Microsoft.KeyVault(SecretUri=', parameters('azureOpenAIKeySecretUri'), ')'))]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[parameters('azureOpenAIEndpoint')]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[parameters('azureOpenAIDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_API_VERSION",
              "value": "[parameters('azureOpenAIAPIVersion')]"
            },
            {
              "name": "DOC_INTELLIGENCE_ENDPOINT",
              "value": "[parameters('docIntelligenceEndpoint')]"
            },
            {
              "name": "DOC_INTELLIGENCE_KEY",
              "value": "[if(equals(parameters('docIntelligenceKeySecretUri'), ''), '', concat('@Microsoft.KeyVault(SecretUri=', parameters('docIntelligenceKeySecretUri'), ')'))]"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8000"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "true"
            },
            {
              "name": "DOCKER_ENABLE_CI",
              "value": "[if(parameters('enableAutomaticUpdates'), 'true', 'false')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[concat('https://', variables('acrLoginServer'))]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[variables('acrUsername')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "KEY_VAULT_NAME",
              "value": "[parameters('existingKeyVaultName')]"
            },
            {
              "name": "WEB_APP_NAME",
              "value": "[variables('webAppName')]"
            },
            {
              "name": "REDIRECT_URI",
              "value": "[concat('https://', variables('webAppName'), '.azurewebsites.net/login_azure')]"
            },
            {
              "name": "APP_CLIENT_ID",
              "value": "[parameters('APP_CLIENT_ID')]"
            },
            {
              "name": "APP_CLIENT_SECRET",
              "value": "[parameters('APP_CLIENT_SECRET')]"
            },
            {
              "name": "APP_TENANT_ID",
              "value": "[parameters('tenantId')]"
            },
            {
              "name": "APP_ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "APP_ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "APP_ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "AUTO_PROMOTE_ADMIN",
              "value": "[if(parameters('autoPromoteAdmin'), 'true', 'false')]"
            },
            {
              "name": "ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "DEFAULT_EMBEDDING_MODEL",
              "value": "[parameters('defaultEmbeddingModel')]"
            },
            {
              "name": "AZURE_EMBEDDING_DEPLOYMENT",
              "value": "[parameters('azureEmbeddingDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_RESOURCE_NAME",
              "value": "[parameters('openAIAzureName')]"
            },
            {
              "name": "DATA_VOLUME_PATH",
              "value": "/home/data"
            },
            {
              "name": "UPLOAD_TEMP_DIR",
              "value": "/home/data/tmp_uploads"
            },
            {
              "name": "MAP_PUBLIC_DIR",
              "value": "/home/data/maps"
            },
            {
              "name": "VECTOR_STORE_BASE_PATH",
              "value": "/home/data/chroma"
            },
            {
              "name": "APP_EDITION",
              "value": "BASIC"
            },
            {
              "name": "SQLALCHEMY_DATABASE_URI",
              "value": "sqlite:////home/data/app.db"
            },
            {
              "name": "RUN_DEFAULT_MODELS",
              "value": "[if(parameters('runDefaultModels'), 'true', 'false')]"
            },
            {
              "name": "GUNICORN_TIMEOUT",
              "value": "300"
            },
            {
              "name": "MAX_ACTIVE_USERS",
              "value": "10"
            },
            {
              "name": "IS_OCR_LOCAL",
              "value": "false"
            },
            {
              "name": "DOCLING_EXPORT_TYPE",
              "value": "MARKDOWN"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-01-01",
      "name": "[variables('workerAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('sharedAppServicePlanName'))]",
        "publicNetworkAccess": "Disabled",
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', variables('acrLoginServer'), '/', parameters('workerDockerImageName'))]",
          "appCommandLine": "./docker-entrypoint.sh worker",
          "alwaysOn": true,
          "azureStorageAccounts": {
            "data": {
              "type": "AzureFiles",
              "accountName": "[parameters('storageAccountName')]",
              "shareName": "[parameters('dataShareName')]",
              "accessKey": "[variables('storageAccountKeyValue')]",
              "mountPath": "/home/data"
            }
          },
          "appSettings": [
            {
              "name": "CELERY_BROKER_URL",
              "value": "[if(not(equals(parameters('redisConnectionStringSecretUri'), '')), concat('@Microsoft.KeyVault(SecretUri=', parameters('redisConnectionStringSecretUri'), ')'), parameters('redisConnectionString'))]"
            },
            {
              "name": "CELERY_RESULT_BACKEND",
              "value": "[if(not(equals(parameters('redisConnectionStringSecretUri'), '')), concat('@Microsoft.KeyVault(SecretUri=', parameters('redisConnectionStringSecretUri'), ')'), parameters('redisConnectionString'))]"
            },
            {
              "name": "AZURE_OPENAI_API_KEY",
              "value": "[if(equals(parameters('azureOpenAIKeySecretUri'), ''), parameters('azureOpenAIKey'), concat('@Microsoft.KeyVault(SecretUri=', parameters('azureOpenAIKeySecretUri'), ')'))]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[parameters('azureOpenAIEndpoint')]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT",
              "value": "[parameters('azureOpenAIDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_API_VERSION",
              "value": "[parameters('azureOpenAIAPIVersion')]"
            },
            {
              "name": "DOC_INTELLIGENCE_ENDPOINT",
              "value": "[parameters('docIntelligenceEndpoint')]"
            },
            {
              "name": "DOC_INTELLIGENCE_KEY",
              "value": "[if(equals(parameters('docIntelligenceKeySecretUri'), ''), '', concat('@Microsoft.KeyVault(SecretUri=', parameters('docIntelligenceKeySecretUri'), ')'))]"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "true"
            },
            {
              "name": "DOCKER_ENABLE_CI",
              "value": "[if(parameters('enableAutomaticUpdates'), 'true', 'false')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[concat('https://', variables('acrLoginServer'))]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[variables('acrUsername')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "KEY_VAULT_NAME",
              "value": "[parameters('existingKeyVaultName')]"
            },
            {
              "name": "APP_CLIENT_ID",
              "value": "[parameters('APP_CLIENT_ID')]"
            },
            {
              "name": "APP_CLIENT_SECRET",
              "value": "[parameters('APP_CLIENT_SECRET')]"
            },
            {
              "name": "APP_TENANT_ID",
              "value": "[parameters('tenantId')]"
            },
            {
              "name": "APP_ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "APP_ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "APP_ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "AUTO_PROMOTE_ADMIN",
              "value": "[if(parameters('autoPromoteAdmin'), 'true', 'false')]"
            },
            {
              "name": "ADMIN_USERNAME",
              "value": "[parameters('appAdminUsername')]"
            },
            {
              "name": "ADMIN_PASSWORD",
              "value": "[if(equals(parameters('appAdminPasswordSecretUri'), ''), parameters('appAdminPassword'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminPasswordSecretUri'), ')'))]"
            },
            {
              "name": "ADMIN_EMAIL",
              "value": "[if(equals(parameters('appAdminEmailSecretUri'), ''), parameters('appAdminEmail'), concat('@Microsoft.KeyVault(SecretUri=', parameters('appAdminEmailSecretUri'), ')'))]"
            },
            {
              "name": "DEFAULT_EMBEDDING_MODEL",
              "value": "[parameters('defaultEmbeddingModel')]"
            },
            {
              "name": "AZURE_EMBEDDING_DEPLOYMENT",
              "value": "[parameters('azureEmbeddingDeployment')]"
            },
            {
              "name": "AZURE_OPENAI_RESOURCE_NAME",
              "value": "[parameters('openAIAzureName')]"
            },
            {
              "name": "DATA_VOLUME_PATH",
              "value": "/home/data"
            },
            {
              "name": "UPLOAD_TEMP_DIR",
              "value": "/home/data/tmp_uploads"
            },
            {
              "name": "MAP_PUBLIC_DIR",
              "value": "/home/data/maps"
            },
            {
              "name": "VECTOR_STORE_BASE_PATH",
              "value": "/home/data/chroma"
            },
            {
              "name": "APP_EDITION",
              "value": "BASIC"
            },
            {
              "name": "SQLALCHEMY_DATABASE_URI",
              "value": "sqlite:////home/data/app.db"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8080"
            },
            {
              "name": "WORKER_HEALTH_PORT",
              "value": "8080"
            },
            {
              "name": "ENABLE_WORKER_HEALTH_SERVER",
              "value": "true"
            },
            {
              "name": "WEBSITES_CONTAINER_START_TIME_LIMIT",
              "value": "400"
            },
            {
              "name": "RUN_DEFAULT_MODELS",
              "value": "[if(parameters('runDefaultModels'), 'true', 'false')]"
            },
            {
              "name": "IS_OCR_LOCAL",
              "value": "false"
            },
            {
              "name": "DOCLING_EXPORT_TYPE",
              "value": "MARKDOWN"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[concat(variables('webAppName'), '-ai')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web"
      }
    },
    {
      "condition": "[parameters('createStorageRoleAssignment')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('storageAccountName'), resourceId('Microsoft.Web/sites', variables('webAppName')), 'web-storage')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]"
      ],
      "scope": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('storageAccountResourceGroup'), '/providers/Microsoft.Storage/storageAccounts/', parameters('storageAccountName'))]",
      "properties": {
        "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', '0c867c2a-1d8c-454a-a3db-ab2ea1bdc8bb')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-01-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "condition": "[parameters('createStorageRoleAssignment')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('storageAccountName'), resourceId('Microsoft.Web/sites', variables('workerAppName')), 'worker-storage')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('workerAppName'))]"
      ],
      "scope": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('storageAccountResourceGroup'), '/providers/Microsoft.Storage/storageAccounts/', parameters('storageAccountName'))]",
      "properties": {
        "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', '0c867c2a-1d8c-454a-a3db-ab2ea1bdc8bb')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('workerAppName')), '2023-01-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[uri(format('https://{0}.azurewebsites.net', variables('webAppName')), '')]"
    },
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "workerAppName": {
      "type": "string",
      "value": "[variables('workerAppName')]"
    },
    "sharedAppServicePlan": {
      "type": "string",
      "value": "[variables('sharedAppServicePlanName')]"
    },
    "redirectUri": {
      "type": "string",
      "value": "[uri(format('https://{0}.azurewebsites.net', variables('webAppName')), 'login_azure')]",
      "metadata": {
        "description": "Add this URL to your Azure AD App Registration Redirect URIs"
      }
    },
    "keyVaultName": {
      "type": "string",
      "value": "[parameters('existingKeyVaultName')]"
    },
    "costSavings": {
      "type": "object",
      "value": {
        "monthlyCost": "~$30",
        "savings": "~$13 (30%)",
        "description": "Shared App Service Plan reduces costs compared to separate plans"
      }
    },
    "webAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-01-01', 'Full').identity.principalId]"
    },
    "workerAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('workerAppName')), '2023-01-01', 'Full').identity.principalId]"
    },
    "step1_KeyVault_WebApp": {
      "type": "string",
      "value": "[concat('az role assignment create --assignee ', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-01-01', 'Full').identity.principalId, ' --role \"Key Vault Secrets User\" --scope /subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('existingKeyVaultResourceGroup'), '/providers/Microsoft.KeyVault/vaults/', parameters('existingKeyVaultName'))]"
    },
    "step2_KeyVault_Worker": {
      "type": "string",
      "value": "[concat('az role assignment create --assignee ', reference(resourceId('Microsoft.Web/sites', variables('workerAppName')), '2023-01-01', 'Full').identity.principalId, ' --role \"Key Vault Secrets User\" --scope /subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('existingKeyVaultResourceGroup'), '/providers/Microsoft.KeyVault/vaults/', parameters('existingKeyVaultName'))]"
    },
    "step3_Storage_WebApp": {
      "type": "string",
      "value": "[concat('az role assignment create --assignee ', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-01-01', 'Full').identity.principalId, ' --role \"Storage Blob Data Contributor\" --scope /subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('storageAccountResourceGroup'), '/providers/Microsoft.Storage/storageAccounts/', parameters('storageAccountName'))]"
    },
    "step4_Storage_Worker": {
      "type": "string",
      "value": "[concat('az role assignment create --assignee ', reference(resourceId('Microsoft.Web/sites', variables('workerAppName')), '2023-01-01', 'Full').identity.principalId, ' --role \"Storage Blob Data Contributor\" --scope /subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('storageAccountResourceGroup'), '/providers/Microsoft.Storage/storageAccounts/', parameters('storageAccountName'))]"
    },
    "step5_RestartApps": {
      "type": "string",
      "value": "[concat('az webapp restart --name ', variables('webAppName'), ' --resource-group ', resourceGroup().name, ' && az webapp restart --name ', variables('workerAppName'), ' --resource-group ', resourceGroup().name)]"
    },
    "step6_Redis_WebApp_IPs": {
      "type": "string",
      "value": "[if(parameters('configureRedisFirewall'), concat('# Web App outbound IPs (add firewall rules for each):\n# ', replace(reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-01-01').outboundIpAddresses, ',', '\n# ')), 'Redis firewall not configured (configureRedisFirewall=false)')]"
    },
    "step7_Redis_Worker_IPs": {
      "type": "string",
      "value": "[if(parameters('configureRedisFirewall'), concat('# Worker App outbound IPs (add firewall rules for each):\n# ', replace(reference(resourceId('Microsoft.Web/sites', variables('workerAppName')), '2023-01-01').outboundIpAddresses, ',', '\n# ')), 'Redis firewall not configured (configureRedisFirewall=false)')]"
    },
    "step8_Redis_Firewall_Command": {
      "type": "string",
      "value": "[if(parameters('configureRedisFirewall'), concat('# Run this command for EACH IP address listed above:\naz redis firewall-rules create --resource-group ', parameters('redisResourceGroup'), ' --name ', parameters('redisName'), ' --rule-name AllowAppService-<IP> --start-ip <IP> --end-ip <IP>\n\n# Example:\n# az redis firewall-rules create --resource-group ', parameters('redisResourceGroup'), ' --name ', parameters('redisName'), ' --rule-name AllowWebApp-1 --start-ip 1.2.3.4 --end-ip 1.2.3.4'), 'Redis firewall not configured (configureRedisFirewall=false)')]"
    },
    "deployedResourceGroup": {
      "type": "string",
      "value": "[parameters('resourceGroup')]"
    }
  }
}