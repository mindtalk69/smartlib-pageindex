# ============================================================================
# SmartLib BASIC - Single Container
# Runs: Redis + Celery Worker + Gunicorn (web) via supervisord
# One image, one container, no external dependencies.
# ============================================================================

# ─── Stage 1: Build frontend assets ────────────────────────────────────────
FROM node:20-alpine AS assets
WORKDIR /app
COPY package.json ./
RUN npm install --silent
COPY vite.config.js ./
COPY static ./static
RUN npm run build

# ─── Stage 2: Python base ───────────────────────────────────────────────────
FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=on \
    PYTHONPATH=/app \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System dependencies + Redis server + supervisor
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    libffi-dev \
    libjpeg-dev \
    zlib1g-dev \
    libpng-dev \
    libxml2-dev \
    libxslt1-dev \
    libssl-dev \
    libgl1 \
    libglib2.0-0 \
    redis-server \
    supervisor \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# ─── Stage 3: Install Python dependencies ──────────────────────────────────
FROM base AS python

# Worker requirements include langchain-huggingface + docling for local Qwen3 embeddings
COPY requirements-worker.txt /tmp/requirements-worker.txt
COPY requirements-web.txt /tmp/requirements-web.txt

# Install CPU-only torch FIRST using the PyTorch CPU wheel index.
# This prevents transitive dependencies (docling, sentence-transformers) from
# pulling the much larger CUDA/NVIDIA variant of torch (~2.8GB vs ~250MB).
RUN pip install --no-cache-dir \
    --extra-index-url https://download.pytorch.org/whl/cpu \
    -r /tmp/requirements-worker.txt \
    -r /tmp/requirements-web.txt


# ─── Stage 4: Final image ───────────────────────────────────────────────────
FROM python AS final

# Copy application code
COPY . /app

# Copy built frontend assets
COPY --from=assets /app/static/dist /app/static/dist

# Copy supervisord configuration
COPY supervisord.conf /etc/supervisor/conf.d/smartlib.conf

# Create data and Redis persistence directories
RUN mkdir -p /home/data/redis /home/data/hf_cache \
    && chmod -R 777 /home/data \
    && chmod +x /app/docker-entrypoint.sh

# Default environment for single-container mode
ENV PORT=8000 \
    WORKERS=1 \
    GUNICORN_TIMEOUT=300 \
    APP_EDITION=BASIC \
    LOCAL_MODE=true \
    # Redis runs inside the container on localhost
    CELERY_BROKER_URL=redis://localhost:6379/0 \
    CELERY_RESULT_BACKEND=redis://localhost:6379/0 \
    STREAM_BUS_URL=redis://localhost:6379/0 \
    VECTOR_STORE_PROVIDER=sqlite-vec \
    SKIP_DATA_MOUNT_CHECK=true \
    EMBEDDING_CACHE_DIR=/home/data/hf_cache

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

EXPOSE 8000

# supervisord manages Redis + Celery + Gunicorn
CMD ["supervisord", "-c", "/etc/supervisor/conf.d/smartlib.conf"]

# ============================================================================
# Build:  docker build -f Dockerfile.single -t smartlib-basic:latest .
# Run:    docker run -p 8000:8000 -v ./data:/home/data \
#           --env-file .env.dev smartlib-basic:latest
# ============================================================================
